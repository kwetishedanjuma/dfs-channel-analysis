{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# DFS System Analysis\n",
    "Multi-scale statistical analysis of distributive fluvial systems using manual digitisation data.\n",
    "This notebook processes channel geometry and environmental distributions for a single system."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "import-packages",
   "metadata": {},
   "outputs": [],
   "source": [
    "# IMPORT PACKAGES\n",
    "import scienceplots\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import statsmodels.api as sm\n",
    "import matplotlib.pyplot as plt\n",
    "from moepy import lowess\n",
    "plt.style.use(['science','ieee'])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Long Profile Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "long-profile",
   "metadata": {},
   "outputs": [],
   "source": [
    "# LOAD LONG PROFILE DATA\n",
    "lonPro = pd.read_excel('colombia06RiverData.xlsx', sheet_name='riverLongProfile')\n",
    "lonPro"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "lowess-fit",
   "metadata": {},
   "outputs": [],
   "source": [
    "# SELECT VARIABLES\n",
    "x = lonPro['distance_km'].values\n",
    "y = lonPro['elevation_m'].values\n",
    "\n",
    "# MODEL FITTING\n",
    "lowess_model = lowess.Lowess()\n",
    "lowess_model.fit(x,y)\n",
    "\n",
    "# MODEL PREDICTION\n",
    "x_pred = np.linspace(x.min(), x.max(), 30) \n",
    "y_pred = lowess_model.predict(x_pred)\n",
    "\n",
    "# PLOTTING\n",
    "plt.plot(lonPro['distance_km'], lonPro['elevation_m'],label='Raw Data', color='#1F77B4')\n",
    "plt.plot(x_pred, y_pred, '-', label='LOWESS', color='#FF7F0E', zorder=6)\n",
    "plt.xlabel(\"Distance ($km$)\")\n",
    "plt.ylabel(\"Elevation ($m$)\")\n",
    "plt.margins(0.05,0.1)\n",
    "plt.legend(frameon=True)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "slope",
   "metadata": {},
   "outputs": [],
   "source": [
    "# SLOPE\n",
    "x1 = lonPro['distance_km'][0]*1000\n",
    "y1 = lonPro['elevation_m'][0]\n",
    "\n",
    "xLast = lonPro['distance_km'].iloc[-1]*1000\n",
    "yLast = lonPro['elevation_m'].iloc[-1]\n",
    "\n",
    "slope = (yLast-y1)/(xLast-x1)\n",
    "print('Slope:', slope, '| Abs Slope:', abs(slope))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cross Section Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "load-cross-section",
   "metadata": {},
   "outputs": [],
   "source": [
    "# LOAD DATASET\n",
    "river = pd.read_excel('colombia06RiverData.xlsx', sheet_name='manualCrossSection')\n",
    "river"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "best-fit-channelbelt-wetted",
   "metadata": {},
   "outputs": [],
   "source": [
    "# find line of best fit\n",
    "a, b = np.polyfit(river.segment, river.channelBelt, 1) # channel belt\n",
    "c, d = np.polyfit(river.segment, river.wettedChannel, 1) # wetted channel\n",
    "\n",
    "with plt.style.context(['science', 'nature']):\n",
    "    plt.scatter(river.segment, river.channelBelt, color='#000000')\n",
    "    plt.scatter(river.segment, river.wettedChannel, color='#1F77B4')\n",
    "    plt.plot(river.segment, a*river.segment+b, color='#dc0500ff')\n",
    "    plt.plot(river.segment, c*river.segment+d, color='#FF7F0E')\n",
    "    plt.xlabel('\\% total distance')\n",
    "    plt.ylabel('Width ($km$)')\n",
    "    plt.margins(0.05,0.2)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ols-wetted",
   "metadata": {},
   "outputs": [],
   "source": [
    "# OLS regression: segment vs wetted channel\n",
    "y = river.wettedChannel\n",
    "x = sm.add_constant(river.segment)\n",
    "model = sm.OLS(y, x).fit()\n",
    "model.summary()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ols-channelbelt",
   "metadata": {},
   "outputs": [],
   "source": [
    "# OLS regression: segment vs channel belt\n",
    "y = river.channelBelt\n",
    "x = sm.add_constant(river.segment)\n",
    "model = sm.OLS(y, x).fit()\n",
    "model.summary()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Water vs Bar Complex"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "water-bar-plot",
   "metadata": {},
   "outputs": [],
   "source": [
    "river.plot(x=\"segment\", y=['wettedChannel','barComplex'], kind=\"bar\", stacked=True,\n",
    "           color=['#4477aa', '#ee8866'])\n",
    "plt.xlabel(\"\\% total distance\")\n",
    "plt.ylabel(\"Width ($km$)\")\n",
    "plt.margins(0.05,0.19)\n",
    "plt.legend(['Wetted Channel','Bar Complex'])\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "water-bar-normalised",
   "metadata": {},
   "outputs": [],
   "source": [
    "riverCopy_1 = river.copy()\n",
    "riverCopy_1[['wettedChannel', 'barComplex']] = riverCopy_1[['wettedChannel', 'barComplex']].apply(lambda x: x/x.sum(), axis=1).multiply(100)\n",
    "riverCopy_1.plot(x=\"segment\", y=['wettedChannel','barComplex'], kind=\"bar\", stacked=True,\n",
    "                color=['#4477aa', '#ee8866'])\n",
    "plt.xlabel(\"\\% total distance\")\n",
    "plt.ylabel(\"Width normalised ($\\%$)\")\n",
    "plt.legend(['Wetted Channel','Bar Complex'])\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "best-fit-barcomplex",
   "metadata": {},
   "outputs": [],
   "source": [
    "a, b = np.polyfit(river.segment, river.barComplex, 1)\n",
    "with plt.style.context(['science', 'nature']):\n",
    "    plt.scatter(river.segment, river.barComplex)\n",
    "    plt.plot(river.segment, a*river.segment+b, color='#FF7F0E')\n",
    "    plt.xlabel('\\% total distance')\n",
    "    plt.ylabel('Channel Width ($km$)')\n",
    "    plt.margins(0.05,0.2)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ols-barcomplex",
   "metadata": {},
   "outputs": [],
   "source": [
    "y = river.barComplex\n",
    "x = sm.add_constant(river.segment)\n",
    "model = sm.OLS(y, x).fit()\n",
    "model.summary()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Water vs Veg/Unveg Bar"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "water-veg-unveg-plot",
   "metadata": {},
   "outputs": [],
   "source": [
    "river.plot(x=\"segment\", y=['wettedChannel','unvegetatedBar', 'vegetatedBar'], kind=\"bar\", stacked=True,\n",
    "           color=['#4477aa', '#ccbb44','#009988'])\n",
    "plt.xlabel(\"\\% total distance\")\n",
    "plt.ylabel(\"Width ($km$)\")\n",
    "plt.margins(0.05,0.19)\n",
    "plt.legend(['Wetted Channel','Unvegetated Bar', 'Vegetated Bar'])\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "water-veg-unveg-normalised",
   "metadata": {},
   "outputs": [],
   "source": [
    "riverCopy_2 = river.copy()\n",
    "riverCopy_2[['wettedChannel', 'unvegetatedBar', 'vegetatedBar']] = riverCopy_2[['wettedChannel', 'unvegetatedBar', 'vegetatedBar']].apply(lambda x: x/x.sum(), axis=1).multiply(100)\n",
    "riverCopy_2.plot(x=\"segment\", y=['wettedChannel','unvegetatedBar', 'vegetatedBar'], kind=\"bar\", stacked=True,\n",
    "                color=['#4477aa', '#ccbb44','#009988'])\n",
    "plt.xlabel(\"\\% total distance\")\n",
    "plt.ylabel(\"Width normalised ($\\%$)\")\n",
    "plt.legend(['Wetted Channel','Unvegetated Bar', 'Vegetated Bar'])\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "best-fit-unvegbar",
   "metadata": {},
   "outputs": [],
   "source": [
    "a, b = np.polyfit(river.segment, river.unvegetatedBar, 1)\n",
    "with plt.style.context(['science', 'nature']):\n",
    "    plt.scatter(river.segment, river.unvegetatedBar)\n",
    "    plt.plot(river.segment, a*river.segment+b, color='#FF7F0E')\n",
    "    plt.xlabel('\\% total distance')\n",
    "    plt.ylabel('Channel Width ($km$)')\n",
    "    plt.margins(0.05,0.2)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ols-unvegbar",
   "metadata": {},
   "outputs": [],
   "source": [
    "y = river.unvegetatedBar\n",
    "x = sm.add_constant(river.segment)\n",
    "model = sm.OLS(y, x).fit()\n",
    "model.summary()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## System Area Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "system-area-plot",
   "metadata": {},
   "outputs": [],
   "source": [
    "sumArea = pd.read_excel('colombia06RiverData.xlsx', sheet_name='manualReach')\n",
    "sumArea.plot(x=\"segment\", y=['waterArea', 'bar'], kind=\"bar\", stacked=True,\n",
    "             color=['#4477aa', '#ee8866'])\n",
    "plt.xlabel(\"\\% total distance\")\n",
    "plt.ylabel(\"Area ($km^2$)\")\n",
    "plt.legend(['Wetted Channel', 'Bar Complex'])\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "system-area-normalised",
   "metadata": {},
   "outputs": [],
   "source": [
    "sumArea_1 = sumArea.copy()\n",
    "sumArea_1[['waterArea', 'bar']] = sumArea_1[['waterArea', 'bar']].apply(lambda x: x/x.sum(), axis=1).multiply(100)\n",
    "sumArea_1.plot(x=\"segment\", y=['waterArea', 'bar'], kind=\"bar\", stacked=True,\n",
    "               color=['#4477aa', '#ee8866'])\n",
    "plt.xlabel(\"\\% total distance\")\n",
    "plt.ylabel(\"Area normalised ($\\%$)\")\n",
    "plt.legend(['Wetted Channel', 'Bar Complex'])\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "system-area-bestfit",
   "metadata": {},
   "outputs": [],
   "source": [
    "a, b = np.polyfit(sumArea.segment, sumArea.bar, 1)\n",
    "with plt.style.context(['science', 'nature']):\n",
    "    plt.scatter(sumArea.segment, sumArea.bar)\n",
    "    plt.plot(sumArea.segment, a*sumArea.segment+b, color='#FF7F0E')\n",
    "    plt.xlabel('% total distance')\n",
    "    plt.ylabel('Channel Width ($km$)')\n",
    "    plt.margins(0.05,0.05)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "system-area-ols",
   "metadata": {},
   "outputs": [],
   "source": [
    "y = sumArea.bar\n",
    "x = sm.add_constant(sumArea.segment)\n",
    "model = sm.OLS(y, x).fit()\n",
    "model.summary()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Multi-Environment Area Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "multi-env-plot",
   "metadata": {},
   "outputs": [],
   "source": [
    "sumArea.plot(x=\"segment\", y=['waterArea', 'sedimentArea', 'vegetationArea'], kind=\"bar\", stacked=True,\n",
    "             color=['#4477aa', '#ccbb44', '#009988'])\n",
    "plt.xlabel(\"\\% total distance\")\n",
    "plt.ylabel(\"Area ($km^2$)\")\n",
    "plt.legend(['Wetted Channel', 'Unvegetated Bar', 'Vegetated Bar'])\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "multi-env-normalised",
   "metadata": {},
   "outputs": [],
   "source": [
    "sumArea_1 = sumArea.copy()\n",
