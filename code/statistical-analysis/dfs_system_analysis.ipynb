
{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# DFS System Analysis\n",
    "Multi-scale statistical analysis for distributive fluvial systems.\n",
    "Set the system Excel file below and run all cells for analysis."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "setup",
   "metadata": {},
   "outputs": [],
   "source": [
    "# === CONFIGURABLE PARAMETERS ===\n",
    "DATA_PATH = \"../data/rio_fragua_chorroso_analysis_data.xlsx\"  # <--- change for other systems\n",
    "\n",
    "SHEETS = {\n",
    "    \"channel_profile\": \"channel_profile\",\n",
    "    \"cross_section_scale\": \"cross_section_scale\",\n",
    "    \"system_scale\": \"system_scale\",\n",
    "    \"domain_scale\": \"domain_scale\",\n",
    "    \"reach_scale\": \"reach_scale\"\n",
    "}\n",
    "\n",
    "import scienceplots\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import statsmodels.api as sm\n",
    "import matplotlib.pyplot as plt\n",
    "from moepy import lowess\n",
    "plt.style.use(['science','ieee'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ols-func",
   "metadata": {},
   "outputs": [],
   "source": [
    "def ols_regression(df, y_col, x_col='segment'):\n",
    "    y = df[y_col]\n",
    "    x = sm.add_constant(df[x_col])\n",
    "    model = sm.OLS(y, x).fit()\n",
    "    print(f\"OLS regression for {y_col} vs {x_col}:\")\n",
    "    print(model.summary())\n",
    "    return model"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Load Data Sheets"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "load-data",
   "metadata": {},
   "outputs": [],
   "source": [
    "channel_profile = pd.read_excel(DATA_PATH, sheet_name=SHEETS[\"channel_profile\"])\n",
    "cross_section = pd.read_excel(DATA_PATH, sheet_name=SHEETS[\"cross_section_scale\"])\n",
    "system_scale = pd.read_excel(DATA_PATH, sheet_name=SHEETS[\"system_scale\"])\n",
    "domain_scale = pd.read_excel(DATA_PATH, sheet_name=SHEETS[\"domain_scale\"])\n",
    "reach_scale = pd.read_excel(DATA_PATH, sheet_name=SHEETS[\"reach_scale\"])\n",
    "\n",
    "channel_profile.head(), cross_section.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Channel Profile Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "lowess-profile",
   "metadata": {},
   "outputs": [],
   "source": [
    "x = channel_profile['distance_km'].values\n",
    "y = channel_profile['elevation_m'].values\n",
    "\n",
    "lowess_model = lowess.Lowess()\n",
    "lowess_model.fit(x,y)\n",
    "x_pred = np.linspace(x.min(), x.max(), 30)\n",
    "y_pred = lowess_model.predict(x_pred)\n",
    "\n",
    "plt.plot(channel_profile['distance_km'], channel_profile['elevation_m'], label='Raw Data', color='#1F77B4')\n",
    "plt.plot(x_pred, y_pred, '-', label='LOWESS', color='#FF7F0E', zorder=6)\n",
    "plt.xlabel(\"Distance ($km$)\")\n",
    "plt.ylabel(\"Elevation ($m$)\")\n",
    "plt.legend(frameon=True)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## OLS Regression for All Environment Types"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ols-all-environments",
   "metadata": {},
   "outputs": [],
   "source": [
    "env_cols = ['channelBelt', 'wettedChannel', 'barComplex', 'unvegetatedBar', 'vegetatedBar']\n",
    "for col in env_cols:\n",
    "    if col in cross_section.columns:\n",
    "        _ = ols_regression(cross_section, col)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Plotting Examples (Bar Plots etc.)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "plotting-examples",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Example: Water vs Bar Complex\n",
    "cols_to_plot = [c for c in ['wettedChannel', 'barComplex'] if c in cross_section.columns]\n",
    "if cols_to_plot:\n",
    "    cross_section.plot(x=\"segment\", y=cols_to_plot, kind=\"bar\", stacked=True, color=['#4477aa', '#ee8866'])\n",
    "    plt.xlabel(\"% total distance\")\n",
    "    plt.ylabel(\"Width ($km$)\")\n",
    "    plt.legend(cols_to_plot)\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Additional Analysis (System, Domain, Reach Scales)\n",
    "Repeat similar OLS/statistical analysis for each sheet as needed."
   ]
  }
 ],
