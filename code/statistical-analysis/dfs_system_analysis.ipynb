    "sumArea_1.plot(x=\"segment\", y=['waterArea', 'sedimentArea', 'vegetationArea'], kind=\"bar\", stacked=True,\n",
    "               color=['#4477aa', '#ccbb44', '#009988'])\n",
    "plt.xlabel(\"\\% total distance\")\n",
    "plt.ylabel(\"Area normalised ($\\%$)\")\n",
    "plt.legend(['Wetted Channel', 'Unvegetated Bar', 'Vegetated Bar'])\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "multi-env-bestfit",
   "metadata": {},
   "outputs": [],
   "source": [
    "a, b = np.polyfit(sumArea.segment, sumArea.waterArea, 1)\n",
    "with plt.style.context(['science', 'nature']):\n",
    "    plt.scatter(sumArea.segment, sumArea.waterArea)\n",
    "    plt.plot(sumArea.segment, a*sumArea.segment+b, color='#FF7F0E')\n",
    "    plt.xlabel('% total distance')\n",
    "    plt.ylabel('Channel Width ($km$)')\n",
    "    plt.margins(0.05,0.2)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "multi-env-ols",
   "metadata": {},
   "outputs": [],
   "source": [
    "y = sumArea.sedimentArea\n",
    "x = sm.add_constant(sumArea.segment)\n",
    "model = sm.OLS(y, x).fit()\n",
    "model.summary()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## System-Wide Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "systemwide-piechart",
   "metadata": {},
   "outputs": [],
   "source": [
    "sumArea_2 = pd.read_excel('colombia06RiverData.xlsx', sheet_name='manualSystemWide')\n",
    "plot = sumArea_2.plot.pie(y='area', legend=False, \\\n",
    "                   autopct=\"%1.1f%%\", explode=(0.0, 0, 0), \\\n",
    "                   shadow=False, startangle=90, colors=['#4477aa', '#ccbb44','#009988'])\n",
    "plt.axis('equal')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Proximal-Medial-Distal Domain Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "domain-plot",
   "metadata": {},
   "outputs": [],
   "source": [
    "proDistalArea = pd.read_excel('colombia06RiverData.xlsx', sheet_name='manualDomain')\n",
    "proDistalArea.plot(x=\"zone\", y=['waterArea', 'sedimentArea', 'vegetationArea'], kind=\"bar\", stacked=True,\n",
    "                   color=['#4477aa', '#ccbb44','#009988'])\n",
    "plt.xlabel(\"\")\n",
    "plt.xticks(rotation = 360)\n",
    "plt.ylabel(\"Area ($km^2$)\")\n",
    "plt.margins(0.05,0.08)\n",
    "plt.legend(['Wetted Channel','Unvegetated Bar', 'Vegetated Bar'])\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "domain-normalised",
   "metadata": {},
