    "print(f\"Detailed environmental plot saved: {detailed_env_file}\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CREATE NORMALISED ENVIRONMENTAL PROPORTIONS\n",
    "riverCopy_2 = river.copy()\n",
    "\n",
    "# CONVERT ROW VALUES TO PERCENTAGES\n",
    "riverCopy_2[env_cols] = riverCopy_2[env_cols].apply(lambda x: x/x.sum(), axis=1).multiply(100)\n",
    "\n",
    "print(f\"Normalised detailed environmental proportions:\")\n",
    "display(riverCopy_2[env_cols].head())\n",
    "\n",
    "# CREATE NORMALISED DETAILED PLOT\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "riverCopy_2.plot(x=\"segment\",\n",
